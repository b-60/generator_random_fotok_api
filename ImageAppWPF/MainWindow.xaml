<Window x:Class="ImageAppWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Генератор картинок (Версия 1)" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Случайная картинка" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <Button Content="Показать случайную картинку" Click="BtnShow_Click" Padding="15,10" FontSize="14" Cursor="Hand"/>
            <TextBlock x:Name="TxtStatus" Text="Нажмите кнопку для загрузки..." HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="Gray"/>
        </StackPanel>
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
            <Image x:Name="ImgDisplay" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="Версия 1 | Автор: " FontWeight="Bold"/>
            <TextBlock Text="B-60" Foreground="Blue"/>
        </StackPanel>
    </Grid>
</Window>